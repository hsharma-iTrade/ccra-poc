import re
from pathlib import Path

src = Path("app.py").read_text()
oms_span = "<span class='brand-oms-word'>OMS</span>"

print("=" * 60)
print("CHECK 1 — Tile click wires to selected_classification")
print("=" * 60)
pat = re.compile(
    r'st\.button\(\s*[^)]*key=f"tile_btn_\{code\}".*?'
    r'st\.session_state\.selected_classification\s*=\s*\(\s*None if active else code\s*\)',
    re.DOTALL,
)
m = pat.search(src)
print(f"  tile button -> selected_classification wiring: {'PASS' if m else 'FAIL'}")

ck = src.count('st.container(key=f"tile-{code}")')
