"""
Unit-level test of the new helpers without launching Streamlit's full runtime.
We import app.py's helpers by monkey-patching st.session_state with a dict-like.
"""
import importlib, sys, types

# Stub streamlit BEFORE importing app.py so module top-level side effects don't crash.
class _SS(dict):
    def __getattr__(self, k):
        try: return self[k]
        except KeyError: raise AttributeError(k)
    def __setattr__(self, k, v):
        self[k] = v

class _StubMarkdownEtc:
    def __getattr__(self, name):
        def _fn(*a, **kw):
            class _Ctx:
                def __enter__(s): return s
                def __exit__(s, *a): return False
            return _Ctx()
        return _fn

st_stub = types.ModuleType("streamlit")
st_stub.session_state = _SS()
st_stub.cache_data = lambda fn=None, **kw: (fn if fn else (lambda f: f))
st_stub.set_page_config = lambda **kw: None
for nm in ("markdown","caption","button","columns","container","divider","metric",
           "popover","file_uploader","camera_input","rerun","info","write","title",
           "header","subheader","text","code","success","warning","error","tabs",
           "selectbox","radio","number_input","text_input","text_area","dataframe",
           "table","metric","progress","empty","sidebar","stop","plotly_chart",
           "altair_chart","image","video","audio","balloons","snow","toast",
           "expander","form","form_submit_button","download_button","spinner",
           "set_option","cache_resource"):
    setattr(st_stub, nm, _StubMarkdownEtc().__getattr__(nm))

sys.modules["streamlit"] = st_stub

# Stub pandas to avoid heavy import (app imports `pd` at top level).
sys.modules.setdefault("pandas", types.ModuleType("pandas"))

import app  # this runs top-level code

# Verify session-state keys are seeded by _init_state.
expected_keys = {"user_uploaded_artifacts", "last_processed_pdf_name",
                 "last_processed_camera_id", "page", "payments",
                 "ingested_fixture_ids", "selected_classification",
                 "selected_payment_id", "selected_line_index", "show_draft"}
missing = expected_keys - set(st_stub.session_state.keys())
print(f"Missing state keys: {missing or 'NONE - all seeded'}")

# Test _sanitize_filename
print()
print("=== _sanitize_filename ===")
for raw, exp in [("hello.pdf","hello.pdf"),
                 ("../../../etc/passwd","_.._.._etc_passwd"),
                 ("a b c.pdf","a b c.pdf"),
                 ("weird;rm -rf;.pdf","weird_rm -rf_.pdf"),
                 ("",  "unnamed")]:
    got = app._sanitize_filename(raw)
    print(f"  {raw!r:40s} -> {got!r}")

# Test _unique_filename (collisions)
print()
print("=== _unique_filename ===")
st_stub.session_state.user_uploaded_artifacts = [
    {"artifact_name": "x.pdf"}, {"artifact_name": "x (2).pdf"}
]
for nm in ["fresh.pdf", "x.pdf", "x (2).pdf", "y"]:
    print(f"  {nm!r:20s} -> {app._unique_filename(nm)!r}")

# Test _register_user_upload + FIFO cap
print()
print("=== _register_user_upload + FIFO cap ===")
st_stub.session_state.user_uploaded_artifacts = []
for i in range(25):
    app._register_user_upload(f"file_{i}.pdf", "upload", 2048 + i * 10)
arts = st_stub.session_state.user_uploaded_artifacts
print(f"  Total after 25 uploads (cap=20): {len(arts)} -> {'PASS' if len(arts)==20 else 'FAIL'}")
print(f"  Oldest kept: {arts[0]['artifact_name']}  (expect file_5.pdf): "
      f"{'PASS' if arts[0]['artifact_name']=='file_5.pdf' else 'FAIL'}")
print(f"  Newest:      {arts[-1]['artifact_name']} (expect file_24.pdf): "
      f"{'PASS' if arts[-1]['artifact_name']=='file_24.pdf' else 'FAIL'}")

# Test that camera filename pattern is right
print()
print("=== camera capture filename ===")
from datetime import datetime
sample = f"camera_capture_{datetime.now().strftime('%Y%m%d_%H%M%S')}.png"
import re
ok = re.fullmatch(r"camera_capture_\d{8}_\d{6}\.png", sample) is not None
print(f"  {sample}: {'PASS' if ok else 'FAIL'}")

# Test that ingest_user_upload picks a random fixture and marks ingested
print()
print("=== ingest_user_upload (no real OCR) ===")
st_stub.session_state.user_uploaded_artifacts = []
st_stub.session_state.payments = []
st_stub.session_state.ingested_fixture_ids = set()
app._register_user_upload("my_check.pdf", "upload", 12000)
rec = st_stub.session_state.user_uploaded_artifacts[0]
print(f"  Before ingest: ingested={rec['ingested']}")
# Stub the inner ingest_fixture so we don't need full data pipeline
captured = {}
def fake_ingest(fixture, label):
    captured["fixture_id"] = fixture["fixture_id"]
    captured["filename"]   = fixture["filename"]
    captured["label"]      = label
app.ingest_fixture = fake_ingest
app.ingest_user_upload(rec)
print(f"  After ingest:  ingested={rec['ingested']}")
print(f"  Captured fixture filename: {captured.get('filename')}")
print(f"  Captured fixture_id starts with USERUP-: "
      f"{'PASS' if captured.get('fixture_id','').startswith('USERUP-') else 'FAIL'}")
print(f"  Source label was UPLOAD: {'PASS' if captured.get('label')=='UPLOAD' else 'FAIL'}")
