import re
from pathlib import Path

src = Path('/Users/hsharma/projects/hackathon/ccra-poc/app.py').read_text()

# Find the render_dashboard function body
m = re.search(r'def render_dashboard\(\).*?(?=\ndef |\nclass |\Z)', src, re.DOTALL)
body = m.group(0)

# Extract the tile-rendering loop section (from `for col, code, klass, label, count in tile_specs`)
loop_match = re.search(r'for col, code, klass, label, count in tile_specs:.*?st\.divider\(\)', body, re.DOTALL)
loop = loop_match.group(0)

# Check 1: is st.markdown(..., unsafe_allow_html=True) called on tile_html?
md_call = re.search(r'st\.markdown\(\s*tile_html\s*,\s*unsafe_allow_html\s*=\s*True\s*\)', loop)
print(f"[1] st.markdown(tile_html, unsafe_allow_html=True) present: {'YES' if md_call else 'NO'}")

# Check 2: is the tile_html composed of the tile-label/tile-value/tile-sub divs?
tile_html_def = re.search(r'tile_html\s*=\s*\((.*?)\)', loop, re.DOTALL)
if tile_html_def:
    composition = tile_html_def.group(1)
    has_label = "tile-label" in composition
    has_value = "tile-value" in composition
    has_sub = "tile-sub" in composition
    print(f"[2] tile_html composition includes tile-label/tile-value/tile-sub: {has_label and has_value and has_sub}")
    # Verify no leading indent inside the f-string components (each fragment is a one-liner)
    fragments = re.findall(r'f"(.*?)"', composition)
    multi_line_indented = any(re.search(r'\n\s{4,}', frag) for frag in fragments)
    print(f"[3] HTML fragments contain 4+ space indented multi-line content: {multi_line_indented} (should be False)")

# Check 4: is the st.button used only for accessibility label (NOT for HTML rendering)?
btn_match = re.search(r'st\.button\(\s*aria_label\s*,', loop)
print(f"[4] st.button label is aria_label (plain text), NOT HTML: {'YES' if btn_match else 'NO'}")

# Check 5: confirm no st.text(...) or st.write(...) for tile content
has_text = "st.text(" in loop
has_write_html = re.search(r'st\.write\([^)]*<div', loop)
print(f"[5] No st.text() in tile loop: {'YES' if not has_text else 'NO'}")
print(f"[6] No st.write() with HTML in tile loop: {'YES' if not has_write_html else 'NO'}")
